<%- include('partials/header') %>

<style>
  /* Indifferent, raw typography styles for filter options */
  .filter-opt-btn {
    background: none;
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.95rem;
    color: var(--color-fg);
    padding: 0;
    transition: color 0.15s ease;
    text-transform: lowercase;
  }
  .filter-opt-btn:hover {
    color: var(--color-high);
  }
  .filter-opt-btn.active {
    color: var(--color-high) !important;
    text-decoration: underline;
  }
  
  /* Circular Shutter Button in MEOTTAERO Blue */
  .shutter-btn {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: 3px solid var(--color-fg);
    background-color: var(--color-high);
    cursor: pointer;
    outline: none;
    transition: transform 0.1s ease, background-color 0.2s ease, border-color 0.2s ease;
    box-shadow: 0 0 0 2px var(--color-bg), 0 0 0 3px var(--color-fg);
    padding: 0;
  }
  .shutter-btn:hover {
    transform: scale(1.06);
  }
  .shutter-btn:active {
    transform: scale(0.94);
    background-color: #0000cc;
  }
  .shutter-btn:disabled {
    background-color: #9999ff;
    border-color: #777;
    cursor: not-allowed;
    transform: none;
  }
</style>

<main style="display: flex; flex-direction: column; align-items: center; min-height: calc(100vh - 6rem); box-sizing: border-box;">
  <!-- Spacer above (takes 40% of vertical space) -->
  <div style="flex: 4;"></div>

  <div class="column" style="max-width: 500px; width: 100%; margin: 0 auto; padding: 0 1rem; flex-shrink: 0;">
    
    <!-- Webcam Video / Canvas Wrap -->
    <div class="video-wrap" style="position: relative; width: 100%; aspect-ratio: 4/3; background: #000; border: 1px solid var(--color-fg); margin-bottom: 1.5rem; overflow: hidden; display: flex; align-items: center; justify-content: center;">
      <!-- Hidden Video Element (keeps stream active in background) -->
      <video id="webcam" autoplay playsinline muted style="position: absolute; opacity: 0; pointer-events: none; width: 100%; height: 100%; object-fit: cover; transform: scaleX(-1);"></video>
      <!-- Visible Canvas Preview (displays everything unified) -->
      <canvas id="canvas-preview" style="width: 100%; height: 100%; object-fit: cover;"></canvas>
      
      <!-- Countdown overlay -->
      <div id="countdown" style="display: none; position: absolute; font-size: 8rem; font-weight: 900; color: white; text-shadow: 0 0 25px rgba(0,0,0,0.85); z-index: 10; pointer-events: none; font-family: monospace;">3</div>
      
      <!-- Flash overlay -->
      <div id="flash" style="display: none; position: absolute; top:0; left:0; width:100%; height:100%; background: white; z-index: 11; pointer-events: none;"></div>
      
      <!-- Permission warning -->
      <div id="permission-warning" style="display: none; position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: #111; z-index: 5; flex-direction: column; align-items: center; justify-content: center; padding: 1.5rem; text-align: center; color: white;">
        <p style="margin-bottom: 1rem; font-size: 0.95rem;">📷 카메라 권한이 필요합니다.</p>
        <button id="retry-permission-btn" style="padding: 0.5rem 1rem; border: 1px solid white; background: transparent; color: white; cursor: pointer; font-family: inherit;">허용 요청</button>
      </div>
    </div>
    
    <!-- Capture Controls (Circular Shutter Button) -->
    <div style="margin-bottom: 2rem; display: flex; flex-direction: column; justify-content: center; align-items: center; gap: 0.5rem;">
      <button id="capture-btn" class="shutter-btn" aria-label="Take Photo"></button>
      <div id="upload-status" style="font-family: inherit; font-size: 0.8rem; height: 1.2rem; color: var(--color-high); text-transform: lowercase; font-weight: bold; opacity: 0; transition: opacity 0.2s; pointer-events: none;">uploading...</div>
    </div>

    <!-- Filters Selection (Indifferent Text Links) -->
    <div style="display: flex; gap: 0.75rem; align-items: center; justify-content: center; font-size: 0.95rem; user-select: none;">
      <button class="filter-opt-btn active" data-filter="normal">normal</button>
      <span style="color: var(--color-mid); font-size: 0.85rem; opacity: 0.5;">/</span>
      <button class="filter-opt-btn" data-filter="kinetic">kinetic</button>
      <span style="color: var(--color-mid); font-size: 0.85rem; opacity: 0.5;">/</span>
      <button class="filter-opt-btn" data-filter="tunnel">tunnel</button>
      <span style="color: var(--color-mid); font-size: 0.85rem; opacity: 0.5;">/</span>
      <button class="filter-opt-btn" data-filter="squeeze">squeeze</button>
    </div>
  </div>

  <!-- Spacer below (takes 60% of vertical space) -->
  <div style="flex: 6;"></div>
</main>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    const video = document.getElementById('webcam');
    const canvasPreview = document.getElementById('canvas-preview');
    const captureBtn = document.getElementById('capture-btn');
    const filterBtns = document.querySelectorAll('.filter-opt-btn');
    const countdownOverlay = document.getElementById('countdown');
    const flashOverlay = document.getElementById('flash');
    const warningOverlay = document.getElementById('permission-warning');
    const retryBtn = document.getElementById('retry-permission-btn');

    let stream = null;
    let currentFilter = 'normal';
    
    // Kinetic filter variables
    let loopId = null;
    let lerpBuffer = null;
    const pixelSize = 4;
    const lerpWeight = 0.03;

    // Initialize webcam
    async function initCamera() {
      try {
        warningOverlay.style.display = 'none';
        if (stream) {
          stream.getTracks().forEach(track => track.stop());
        }

        stream = await navigator.mediaDevices.getUserMedia({
          video: { width: 640, height: 480, facingMode: 'user' },
          audio: false
        });
        video.srcObject = stream;
        
        // Start unified canvas animation loop
        startRenderLoop();
      } catch (err) {
        console.error('Camera access error:', err);
        warningOverlay.style.display = 'flex';
      }
    }

    // Retry permission
    retryBtn.addEventListener('click', initCamera);

    // Apply Filter selection
    filterBtns.forEach(btn => {
      btn.addEventListener('click', function () {
        filterBtns.forEach(b => b.classList.remove('active'));
        this.classList.add('active');
        currentFilter = this.getAttribute('data-filter');
      });
    });

    // Unified 60fps Canvas Render Loop
    function startRenderLoop() {
      if (loopId) return;
      
      const ctx = canvasPreview.getContext('2d');
      const offscreen = document.createElement('canvas');
      const offscreenCtx = offscreen.getContext('2d');

      function drawFrame() {
        if (!stream) {
          loopId = requestAnimationFrame(drawFrame);
          return;
        }

        const w = video.videoWidth || 640;
        const h = video.videoHeight || 480;

        if (canvasPreview.width !== w || canvasPreview.height !== h) {
          canvasPreview.width = w;
          canvasPreview.height = h;
        }

        ctx.save();
        
        // Clear background
        ctx.fillStyle = '#000';
        ctx.fillRect(0, 0, w, h);
        ctx.filter = 'none';

        if (currentFilter === 'normal') {
          // Standard Mirrored Draw
          ctx.translate(w, 0);
          ctx.scale(-1, 1);
          ctx.drawImage(video, 0, 0, w, h);
        } 
        else if (currentFilter === 'tunnel') {
          // Infinite Recursive Tunnel
          ctx.translate(w, 0);
          ctx.scale(-1, 1);
          ctx.drawImage(video, 0, 0, w, h);
          
          for (let i = 1; i <= 5; i++) {
            const scale = 1 - (i * 0.15);
            const nw = w * scale;
            const nh = h * scale;
            const nx = (w - nw) / 2;
            const ny = (h - nh) / 2;
            ctx.drawImage(video, nx, ny, nw, nh);
          }
        }
        else if (currentFilter === 'squeeze') {
          // Alien Squeeze Face (Funny narrow stretch)
          ctx.translate(w, 0);
          ctx.scale(-1, 1);
          ctx.drawImage(video, w / 6, 0, w * 0.66, h);
        }
        else if (currentFilter === 'kinetic') {
          // Dreamy Pixelated Lerp Trail
          const cols = Math.floor(w / pixelSize);
          const rows = Math.floor(h / pixelSize);

          if (offscreen.width !== cols || offscreen.height !== rows) {
            offscreen.width = cols;
            offscreen.height = rows;
            lerpBuffer = new Float32Array(cols * rows * 3);
          }

          offscreenCtx.drawImage(video, 0, 0, cols, rows);
          const imgData = offscreenCtx.getImageData(0, 0, cols, rows).data;

          ctx.fillStyle = '#dcdcdc'; // equivalent to background(220)
          ctx.fillRect(0, 0, w, h);

          for (let y = 0; y < rows; y++) {
            for (let x = 0; x < cols; x++) {
              const pixelIdx = (y * cols + x);
              const imgDataIdx = pixelIdx * 4;
              const bufIdx = pixelIdx * 3;

              const targetR = imgData[imgDataIdx];
              const targetG = imgData[imgDataIdx + 1];
              const targetB = imgData[imgDataIdx + 2];

              lerpBuffer[bufIdx] += (targetR - lerpBuffer[bufIdx]) * lerpWeight;
              lerpBuffer[bufIdx + 1] += (targetG - lerpBuffer[bufIdx + 1]) * lerpWeight;
              lerpBuffer[bufIdx + 2] += (targetB - lerpBuffer[bufIdx + 2]) * lerpWeight;

              ctx.fillStyle = `rgb(${Math.round(lerpBuffer[bufIdx])}, ${Math.round(lerpBuffer[bufIdx + 1])}, ${Math.round(lerpBuffer[bufIdx + 2])})`;
              const mirroredX = cols - 1 - x;
              ctx.fillRect(mirroredX * pixelSize, y * pixelSize, pixelSize, pixelSize);
            }
          }
        }

        ctx.restore();
        loopId = requestAnimationFrame(drawFrame);
      }

      loopId = requestAnimationFrame(drawFrame);
    }

    // Web Audio dynamic camera shutter sound synthesizer
    function playShutterSound() {
      try {
        const AudioContext = window.AudioContext || window.webkitAudioContext;
        if (!AudioContext) return;
        const ctx = new AudioContext();
        const osc = ctx.createOscillator();
        const gain = ctx.createGain();
        osc.connect(gain);
        gain.connect(ctx.destination);

        osc.type = 'triangle';
        osc.frequency.setValueAtTime(800, ctx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(150, ctx.currentTime + 0.15);

        gain.gain.setValueAtTime(0.2, ctx.currentTime);
        gain.gain.linearRampToValueAtTime(0.01, ctx.currentTime + 0.15);

        osc.start();
        osc.stop(ctx.currentTime + 0.15);
      } catch (e) {
        console.warn(e);
      }
    }

    // Capture functionality
    captureBtn.addEventListener('click', function () {
      if (!stream) return;

      captureBtn.disabled = true;
      let count = 3;
      countdownOverlay.textContent = count;
      countdownOverlay.style.display = 'block';

      const interval = setInterval(() => {
        count--;
        if (count > 0) {
          countdownOverlay.textContent = count;
        } else {
          clearInterval(interval);
          countdownOverlay.style.display = 'none';
          
          // Flash effect
          flashOverlay.style.display = 'block';
          flashOverlay.style.opacity = 1;
          playShutterSound();

          // Smooth flash animation
          setTimeout(() => {
            flashOverlay.style.transition = 'opacity 0.25s ease';
            flashOverlay.style.opacity = 0;
            setTimeout(() => {
              flashOverlay.style.display = 'none';
              flashOverlay.style.transition = '';
            }, 250);
          }, 50);

          // Get image directly from canvasPreview (unified pipeline guarantees exact visual download)
          const dataUrl = canvasPreview.toDataURL('image/jpeg', 0.9);

          // Trigger direct file download
          const link = document.createElement('a');
          link.download = `meottaero_capture_${Date.now()}.jpg`;
          link.href = dataUrl;
          link.click();

          // Upload to Supabase Storage in the background
          const statusEl = document.getElementById('upload-status');
          statusEl.textContent = 'uploading...';
          statusEl.style.opacity = '1';

          fetch('/api/booth/upload', {
            method: 'POST',
            headers: {
              'Content-Type': 'application/json'
            },
            body: JSON.stringify({ image: dataUrl })
          })
          .then(res => res.json())
          .then(data => {
            if (data.success) {
              statusEl.textContent = 'saved to supabase';
            } else {
              statusEl.textContent = 'upload failed';
            }
            setTimeout(() => {
              statusEl.style.opacity = '0';
            }, 2000);
          })
          .catch(err => {
            console.error('Upload failed:', err);
            statusEl.textContent = 'upload error';
            setTimeout(() => {
              statusEl.style.opacity = '0';
            }, 2000);
          });

          captureBtn.disabled = false;
        }
      }, 1000);
    });

    // Run camera
    initCamera();
  });
</script>

<%- include('partials/footer') %>
