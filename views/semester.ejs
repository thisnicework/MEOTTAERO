                        style="margin-right: 0.5rem; transform: scale(1.1); cursor: pointer;">
                      <span>하우스댄스 워크숍 (7월 24, 25일)</span>
                    </label>
                    <label style="display: flex; align-items: center; cursor: pointer;">
                      <input type="checkbox" name="sessions" value="파티 댄스 워크숍"
                        style="margin-right: 0.5rem; transform: scale(1.1); cursor: pointer;">
                      <span>파티 댄스 워크숍 (7월 31일, 8월 1일)</span>
                    </label>
                    <label style="display: flex; align-items: center; cursor: pointer;">
                      <input type="checkbox" name="sessions" value="댄스 파티"
                        style="margin-right: 0.5rem; transform: scale(1.1); cursor: pointer;">
                      <span>댄스 파티 (8월 7일)</span>
                    </label>
                  </div>
                </div>

                <div class="form-group privacy-group" style="margin-bottom: 1.5rem;">
                  <label class="privacy-label"
