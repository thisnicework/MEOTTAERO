<%- include('partials/header') %>

  <main class="fixed">
    <!-- Left Side: Navigation / Stat Summary -->
    <section id="one" class="left" aria-expanded="true">
      <div class="admin-sidebar" style="padding-right: 1.5rem;">
        <!-- <h2 class="bold" style="color: var(--color-high); margin-bottom: 1.5rem;">ADMIN PANEL</h2> -->

        <div class="stats-panel" style="margin-bottom: 2rem; display: flex; flex-direction: column; gap: 0.75rem;">
          <div class="stat-card"
            style="background: var(--color-low); padding: 1rem; border-left: 4px solid var(--color-high);">
            <h3 class="bold" style="font-size: 0.8rem; margin-bottom: 0.25rem; color: #555;">전체 예매</h3>
            <p class="bold" style="font-size: 1.5rem; color: var(--color-high); margin: 0;" id="total-bookings">
              <%= bookings.length %> 명
            </p>
          </div>
          <% const siaCount = bookings.filter(b => b.eventId === 'the-sia-vol-2').length; %>
          <% const freedomCount = bookings.filter(b => b.eventId === '춤출자유vol-2').length; %>
          <div class="stat-card"
            style="background: var(--color-low); padding: 1rem; border-left: 4px solid #4caf50;">
            <h3 class="bold" style="font-size: 0.8rem; margin-bottom: 0.25rem; color: #555;">THE SIA Vol.2</h3>
            <p class="bold" style="font-size: 1.5rem; color: #4caf50; margin: 0;" id="sia-bookings">
              <%= siaCount %> 명
            </p>
          </div>
          <div class="stat-card"
            style="background: var(--color-low); padding: 1rem; border-left: 4px solid #2196f3;">
            <h3 class="bold" style="font-size: 0.8rem; margin-bottom: 0.25rem; color: #555;">춤 출 자유 Vol.2</h3>
            <p class="bold" style="font-size: 1.5rem; color: #2196f3; margin: 0;" id="freedom-bookings">
              <%= freedomCount %> 명
            </p>
          </div>
        </div>

        <div class="search-panel" style="margin-bottom: 1.5rem;">
          <label for="search-input" class="bold" style="display: block; font-size: 0.85rem; margin-bottom: 0.5rem;">예매 내역 검색 (Search)</label>
          <input type="text" id="search-input" placeholder="이름 또는 연락처 입력..."
            style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-fg); outline: none;">
        </div>

        <div class="filter-panel" style="margin-bottom: 1.5rem;">
          <label for="event-filter" class="bold" style="display: block; font-size: 0.85rem; margin-bottom: 0.5rem;">공연 필터 (Filter by Show)</label>
          <select id="event-filter" style="width: 100%; padding: 0.75rem; border: 1px solid var(--color-fg); outline: none; background: white; font-family: inherit;">
            <option value="all">전체 보기 (All Shows)</option>
            <option value="the-sia-vol-2">THE SIA Vol.2</option>
            <option value="춤출자유vol-2">춤 출 자유 Vol.2</option>
          </select>
        </div>

        <div style="margin-top: 1.5rem;">
          <a href="/admin/export?event=all" class="bold" id="export-link"
            style="display: inline-block; padding: 0.75rem 1.25rem; border: 1px solid var(--color-fg); text-decoration: none; font-size: 0.85rem;">CSV 내보내기 (Excel)</a>
        </div>
      </div>
    </section>

    <!-- Right Side: Booking List Table -->
    <section id="two" class="right" aria-expanded="true">
      <div class="bookings-list-container">
        <h2 class="bold" style="margin-bottom: 1.5rem;">RESERVATION LIST</h2>
        <hr>

        <div style="overflow-x: auto;">
          <table class="admin-table"
            style="width: 100%; border-collapse: collapse; text-align: left; min-width: 700px;">
            <thead>
              <tr style="border-bottom: 2px solid var(--color-fg);">
                <th class="bold" style="padding: 0.75rem 0.5rem;">공연</th>
                <th class="bold" style="padding: 0.75rem 0.5rem;">이름</th>
                <th class="bold" style="padding: 0.75rem 0.5rem;">구분 (학번/참가)</th>
                <th class="bold" style="padding: 0.75rem 0.5rem;">연락처</th>
                <th class="bold" style="padding: 0.75rem 0.5rem; text-align: center; width: 100px;">입금 확인</th>
                <th class="bold" style="padding: 0.75rem 0.5rem; text-align: center; width: 100px;">문자 전송</th>
                <th class="bold" style="padding: 0.75rem 0.5rem; text-align: right;">관리</th>
              </tr>
            </thead>
            <tbody id="bookings-table-body">
              <% if (bookings.length===0) { %>
                <tr class="no-bookings-row">
                  <td colspan="7" style="padding: 2rem; text-align: center; color: var(--color-mid);">등록된 예매 내역이 없습니다.
                  </td>
                </tr>
                <% } else { %>
                  <% bookings.forEach(function(b) { %>
                    <tr class="booking-row" data-code="<%= b.code %>" data-name="<%= b.name %>"
                      data-phone="<%= b.phone %>" data-event-id="<%= b.eventId %>" style="border-bottom: 1px solid var(--color-low);">
                      <td class="bold" style="padding: 0.75rem 0.5rem; font-size: 0.85rem; color: var(--color-mid);">
                        <%= b.eventId === 'the-sia-vol-2' ? 'THE SIA Vol.2' : '춤 출 자유 Vol.2' %>
                      </td>
                      <td class="bold" style="padding: 0.75rem 0.5rem;">
                        <%= b.name %>
                      </td>
                      <td style="padding: 0.75rem 0.5rem;">
                        <%= b.studentId %>
                      </td>
                      <td style="padding: 0.75rem 0.5rem;">
                        <%= b.phone %>
                      </td>
                      <td style="padding: 0.75rem 0.5rem; text-align: center;">
                        <input type="checkbox" class="status-checkbox payment-checkbox" data-code="<%= b.code %>" style="transform: scale(1.2); cursor: pointer;" <%= b.paymentConfirmed ? 'checked' : '' %>>
                      </td>
                      <td style="padding: 0.75rem 0.5rem; text-align: center;">
                        <input type="checkbox" class="status-checkbox sms-checkbox" data-code="<%= b.code %>" style="transform: scale(1.2); cursor: pointer;" <%= b.smsSent ? 'checked' : '' %>>
                      </td>
                      <td style="padding: 0.75rem 0.5rem; text-align: right;">
                        <button class="delete-booking-btn" data-code="<%= b.code %>"
                          style="background: none; border: none; color: var(--color-err); cursor: pointer; font-size: 0.85rem; text-decoration: underline; padding: 0.25rem 0.5rem;">취소</button>
                      </td>
                    </tr>
                    <% }); %>
                      <% } %>
            </tbody>
          </table>
        </div>
      </div>
    </section>
  </main>

  <%- include('partials/footer') %>

    <script>
      document.addEventListener('DOMContentLoaded', function () {
        // 1. Search and Event Filtering
        const searchInput = document.getElementById('search-input');
        const eventFilter = document.getElementById('event-filter');
        const exportLink = document.getElementById('export-link');
        const tableBody = document.getElementById('bookings-table-body');
        
        function filterBookings() {
          const query = searchInput ? searchInput.value.toLowerCase().trim() : '';
          const selectedEvent = eventFilter ? eventFilter.value : 'all';
          const rows = tableBody.querySelectorAll('.booking-row');
          let matchCount = 0;

          rows.forEach(row => {
            const name = row.getAttribute('data-name').toLowerCase();
            const phone = row.getAttribute('data-phone').toLowerCase();
            const eventId = row.getAttribute('data-event-id');

            const matchesQuery = query === '' || name.includes(query) || phone.includes(query);
            const matchesEvent = selectedEvent === 'all' || eventId === selectedEvent;

            if (matchesQuery && matchesEvent) {
              row.style.display = '';
              matchCount++;
            } else {
              row.style.display = 'none';
            }
          });

          // Toggle no results row
          let noResultsRow = document.getElementById('no-results-row');
          if (matchCount === 0 && rows.length > 0) {
            if (!noResultsRow) {
              noResultsRow = document.createElement('tr');
              noResultsRow.id = 'no-results-row';
              noResultsRow.innerHTML = '<td colspan="7" style="padding: 2rem; text-align: center; color: var(--color-mid);">검색 결과가 없습니다.</td>';
              tableBody.appendChild(noResultsRow);
            }
          } else {
            if (noResultsRow) {
              noResultsRow.remove();
            }
          }
        }

        if (searchInput) searchInput.addEventListener('input', filterBookings);
        
        if (eventFilter) {
          eventFilter.addEventListener('change', function () {
            filterBookings();
            // Update CSV export link with the current filter parameter
            if (exportLink) {
              exportLink.href = `/admin/export?event=${this.value}`;
            }
          });
        }

        // 2. Cancel/Delete Booking Action
        tableBody.addEventListener('click', function (e) {
          if (e.target.classList.contains('delete-booking-btn')) {
            const btn = e.target;
            const code = btn.getAttribute('data-code');

            if (!confirm('정말로 이 예매를 취소하시겠습니까?')) {
              return;
            }

            btn.disabled = true;
            btn.textContent = '처리중...';

            fetch('/admin/delete', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({ code })
            })
              .then(res => res.json())
              .then(data => {
                if (data.success) {
                  const row = btn.closest('.booking-row');
                  const eventId = row.getAttribute('data-event-id');

                  // Fade-out row & delete
                  row.style.transition = 'opacity 0.2s';
                  row.style.opacity = 0;
                  setTimeout(() => {
                    row.remove();

                    // Recalculate stats on client side
                    const totalBookingsEl = document.getElementById('total-bookings');
                    const siaBookingsEl = document.getElementById('sia-bookings');
                    const freedomBookingsEl = document.getElementById('freedom-bookings');
                    
                    const currentTotal = parseInt(totalBookingsEl.textContent, 10) || 0;
                    totalBookingsEl.textContent = Math.max(0, currentTotal - 1) + ' 명';
                    
                    if (eventId === 'the-sia-vol-2') {
                      if (siaBookingsEl) {
                        const currentSia = parseInt(siaBookingsEl.textContent, 10) || 0;
                        siaBookingsEl.textContent = Math.max(0, currentSia - 1) + ' 명';
                      }
                    } else {
                      if (freedomBookingsEl) {
                        const currentFreedom = parseInt(freedomBookingsEl.textContent, 10) || 0;
                        freedomBookingsEl.textContent = Math.max(0, currentFreedom - 1) + ' 명';
                      }
                    }

                    // Check if table is empty now
                    const remainingRows = tableBody.querySelectorAll('.booking-row');
                    if (remainingRows.length === 0) {
                      tableBody.innerHTML = `
                  <tr class="no-bookings-row">
                    <td colspan="7" style="padding: 2rem; text-align: center; color: var(--color-mid);">등록된 예매 내역이 없습니다.</td>
                  </tr>
                `;
                    }
                  }, 200);
                } else {
                  alert(data.error || '오류가 발생했습니다.');
                  btn.disabled = false;
                  btn.textContent = '취소';
                }
              })
              .catch(err => {
                alert('서버 통신 오류가 발생했습니다.');
                btn.disabled = false;
                btn.textContent = '취소';
              });
          }
        });

        // 3. Update status checkboxes (paymentConfirmed, smsSent)
        tableBody.addEventListener('change', function (e) {
          if (e.target.classList.contains('status-checkbox')) {
            const checkbox = e.target;
            const code = checkbox.getAttribute('data-code');
            const row = checkbox.closest('.booking-row');
            
            const paymentCheckbox = row.querySelector('.payment-checkbox');
            const smsCheckbox = row.querySelector('.sms-checkbox');
            
            const paymentConfirmed = paymentCheckbox.checked;
            const smsSent = smsCheckbox.checked;
            
            // Disable checkboxes while saving
            paymentCheckbox.disabled = true;
            smsCheckbox.disabled = true;
            
            fetch('/admin/update-status', {
              method: 'POST',
              headers: {
                'Content-Type': 'application/json'
              },
              body: JSON.stringify({ code, paymentConfirmed, smsSent })
            })
              .then(res => res.json())
              .then(data => {
                paymentCheckbox.disabled = false;
                smsCheckbox.disabled = false;
                if (!data.success) {
                  alert(data.error || '상태 업데이트 중 오류가 발생했습니다.');
                  // Revert state
                  checkbox.checked = !checkbox.checked;
                }
              })
              .catch(err => {
                paymentCheckbox.disabled = false;
                smsCheckbox.disabled = false;
                alert('서버 통신 오류가 발생했습니다.');
                checkbox.checked = !checkbox.checked;
              });
          }
        });
      });
    </script>